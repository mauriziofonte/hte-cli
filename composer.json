{
    "name": "mfonte/hte-cli",
    "description": "[H]andle [T]est [E]nvironment CLI tool to create and manage VirtualHosts that are compatible with github.com/mauriziofonte/win11-wsl2-ubuntu22-setup or with any LAMP stack based on Debian or Ubuntu, with Multi PHP-FPM support via mpm_event, proxy_fcgi, and fcgid Apache modules.",
    "homepage": "https://github.com/mauriziofonte/win11-wsl2-ubuntu22-setup",
    "type": "library",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/mauriziofonte/hte-cli/issues",
        "source": "https://github.com/mauriziofonte/hte-cli"
    },
    "authors": [
        {
            "name": "Maurizio Fonte",
            "email": "fonte.maurizio@gmail.com"
        }
    ],
    "require": {
        "php": "^7.3|^8.0",
        "php-school/cli-menu": "^4.3.0"
    },
    "require-dev": {
        "laravel-zero/framework": "^8.8",
        "phpunit/phpunit": "^9.5"
    },
    "scripts": {
        "test": "phpunit",
        "lint": "php -l app/*.php app/**/*.php",
        "check": [
            "@lint",
            "@test"
        ],
        "version": "cat VERSION",
        "version:patch": "php scripts/version-bump.php patch",
        "version:minor": "php scripts/version-bump.php minor",
        "version:major": "php scripts/version-bump.php major",
        "build": "php hte app:build hte-cli --build-version=$(cat VERSION)",
        "release": [
            "@version:patch",
            "@build"
        ]
    },
    "autoload": {
        "psr-4": {
            "Mfonte\\HteCli\\": "app/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": [
        "builds/hte-cli"
    ]
}